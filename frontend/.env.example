# Supabase — copy to .env.local
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Legacy name also supported: VITE_SUPABASE_ANON_KEY

# Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=studiobook_uploads

# OpenRouter — server-side only (Supabase secret). Do NOT put API keys in VITE_*.
# supabase secrets set OPENROUTER_API_KEY=sk-or-v1-...

# OneSignal — web push (public App ID; REST API key stays in Supabase secrets)
VITE_ONESIGNAL_APP_ID=98cf69f1-7952-499b-89de-d3325ed49e3e

# Resend + OneSignal server secrets are set on Supabase (not in Vite):
# supabase secrets set RESEND_API_KEY=re_xxxxxxxxx
# supabase secrets set RESEND_FROM_EMAIL="Studio 8Teen <noreply@yourdomain.com>"
# supabase secrets set ONESIGNAL_APP_ID=98cf69f1-7952-499b-89de-d3325ed49e3e
# supabase secrets set ONESIGNAL_API_KEY=your_onesignal_rest_api_key
# supabase secrets set APP_URL=https://www.studio8teen.org
# supabase functions deploy notify-schedule-change
